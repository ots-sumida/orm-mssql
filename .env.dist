DB_HOST=835227-2
DB_PORT=1433
DB_NAME=sampledb
DB_USER=sa
DB_PASSWORD=sqlserver
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# --- 接続プール（DB 接続の使い回し） ---
# 省略時: max=10, min=0, acquire=30000, idle=10000
# DB_POOL_MAX=10        # 同時に使える接続の上限
# DB_POOL_MIN=0         # 常に維持する接続数（0=使うまで作らない）
# DB_POOL_ACQUIRE=30000 # 接続を借りる最大待ち時間 ms（プール満杯時）
# DB_POOL_IDLE=10000    # 未使用接続を保持する時間 ms（超えたら閉じる）

# --- タイムアウト（単位: ms） ---
# 省略時: connect=15000, request=60000
# DB_CONNECT_TIMEOUT=15000  # 接続確立のタイムアウト（15秒）
# DB_REQUEST_TIMEOUT=60000  # 1クエリのタイムアウト（60秒）

# --- SQL ログ（Sequelize が実行する SQL をコンソール出力） ---
# 省略時: false（本番・テスト向け）
# npm run sample:* は DB_LOGGING 未設定時に自動で true になる
# DB_LOGGING=true
